{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Takk",
  "version": "0.4.3",
  "identifier": "com.vixlabs.taxx",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Takk - Xử lý bảng giá",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "bgx"
        ],
        "name": "Dự án Takk Tham chiếu",
        "description": "Tệp dự án Takk tham chiếu (chỉ lưu đường dẫn)",
        "role": "Editor"
      },
      {
        "ext": [
          "bg"
        ],
        "name": "Dự án Takk Đóng gói",
        "description": "Tệp dự án Takk đóng gói (chứa dữ liệu thô)",
        "role": "Editor"
      }
    ]
  }
}
